{
  "manifest_version": 3,
  "name": "WhatsApp Web Helper",
  "version": "1.1.0",
  "version_name": "1.1.0 Beta 2",
  "description": "Membantu konversi mata uang otomatis dan terjemahan di WhatsApp Web.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://open.er-api.com/*",
    "https://translate.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WA Web Helper Settings"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
