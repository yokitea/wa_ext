{
  "manifest_version": 3,
  "name": "DealCalc",
  "version": "1.1.0",
  "version_name": "1.1.0 RC",
  "description": "Smart Business Calculator and Currency Converter for WhatsApp Web.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://open.er-api.com/*",
    "https://translate.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "DealCalc Settings",
    "default_icon": "image/DealCalc_FINAL_Ext.png"
  },
  "icons": {
    "16": "image/DealCalc_FINAL_Ext.png",
    "48": "image/DealCalc_FINAL_Ext.png",
    "128": "image/DealCalc_FINAL_Ext.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
